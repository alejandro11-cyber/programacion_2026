// Código de ejemplo para conectarse a un modelo de IA usando la API de OpenAI (requiere libcurl y nlohmann/json).
// Instala libcurl y nlohmann/json antes de compilar.
// Compila con: g++ -o ia_api ia_api.cpp -lcurl -std=c++11
// Reemplaza "TU_API_KEY" con tu clave real de OpenAI.

#include <iostream>
#include <curl/curl.h>
#include <nlohmann/json.hpp>
#include <string>

using json = nlohmann::json;

// Función para manejar la respuesta HTTP
size_t WriteCallback(void* contents, size_t size, size_t nmemb, std::string* response) {
    size_t totalSize = size * nmemb;
    response->append((char*)contents, totalSize);
    return totalSize;
}

int main() {
    CURL* curl;
    CURLcode res;
    std::string response;

    curl = curl_easy_init();
    if (curl) {
        // Configurar la URL de la API (ejemplo: completions de OpenAI)
        curl_easy_setopt(curl, CURLOPT_URL, "https://api.openai.com/v1/completions");

        // Configurar headers
        struct curl_slist* headers = NULL;
        headers = curl_slist_append(headers, "Content-Type: application/json");
        headers = curl_slist_append(headers, "Authorization: Bearer TU_API_KEY");
        curl_easy_setopt(curl, CURLOPT_HTTPHEADER, headers);

        // Crear el cuerpo de la solicitud JSON
        json requestBody = {
            {"model", "text-davinci-003"},
            {"prompt", "Hola, ¿cómo estás?"},
            {"max_tokens", 50}
        };
        std::string jsonStr = requestBody.dump();
        curl_easy_setopt(curl, CURLOPT_POSTFIELDS, jsonStr.c_str());

        // Configurar callback para la respuesta
        curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, WriteCallback);
        curl_easy_setopt(curl, CURLOPT_WRITEDATA, &response);

        // Realizar la solicitud
        res = curl_easy_perform(curl);

        if (res != CURLE_OK) {
            std::cerr << "Error en la solicitud: " << curl_easy_strerror(res) << std::endl;
        } else {
            // Procesar la respuesta JSON
            json responseJson = json::parse(response);
            if (responseJson.contains("choices") && !responseJson["choices"].empty()) {
                std::cout << "Respuesta de IA: " << responseJson["choices"][0]["text"] << std::endl;
            }
        }

        // Limpiar
        curl_slist_free_all(headers);b
        curl_easy_cleanup(curl);
    }

    return 0;
}